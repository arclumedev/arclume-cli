{
  "name": "arclume",
  "version": "0.1.0",
  "description": "Configure any repository for optimal Arclume indexing",
  "type": "module",
  "bin": {
    "arclume": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test:manifest": "tsx src/lib/manifest.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
