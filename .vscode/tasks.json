{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tsup: watch",
      "type": "shell",
      "command": "npx tsup src/cli.ts --format esm --watch",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "tsup",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "CLI Building",
          "endsPattern": "Build success"
        }
      }
    },
    {
      "label": "typecheck",
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "test:manifest",
      "type": "npm",
      "script": "test:manifest"
    }
  ]
}
